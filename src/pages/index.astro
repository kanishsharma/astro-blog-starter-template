---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 5);
const [latestPost, ...otherRecentPosts] = recentPosts;
const recentTils = (await getCollection('til'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
const workEntries = (await getCollection('work')).sort((a, b) => {
	const orderDiff = (a.data.order ?? 999) - (b.data.order ?? 999);
	return orderDiff || b.data.startDate.valueOf() - a.data.startDate.valueOf();
});
const projects = (await getCollection('projects'))
	.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999) || a.data.title.localeCompare(b.data.title))
	.slice(0, 4);
const currentWork = workEntries[0];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(58rem, calc(100% - 2rem));
				padding-top: clamp(3rem, 9vw, 7rem);
			}

			.home-hero {
				max-width: 42rem;
				padding: 0 0 clamp(3.5rem, 8vw, 6rem);
			}

			.home-hero h1 {
				margin-bottom: 1.1rem;
				font-family: var(--font-sans);
				font-size: clamp(2rem, 5vw, 3rem);
				font-weight: 700;
				letter-spacing: -0.045em;
			}

			.hero-copy {
				color: var(--text-soft);
				font-family: var(--font-sans);
				font-size: clamp(1.35rem, 3vw, 2rem);
				font-weight: 700;
				line-height: 1.45;
			}

			.content-grid {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(16rem, 0.42fr);
				gap: clamp(1.5rem, 5vw, 3rem);
				align-items: start;
			}

			.kicker,
			.date {
				color: var(--muted);
				font-family: var(--font-sans);
				font-size: 0.72rem;
				letter-spacing: 0.18em;
				text-transform: uppercase;
			}

			.text-link {
				margin-top: 1rem;
				color: var(--accent);
				font-family: var(--font-sans);
				font-size: 0.76rem;
				letter-spacing: 0.16em;
				text-decoration: none;
				text-transform: uppercase;
			}

			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				margin: 2.8rem 0 1.25rem;
				border-bottom: 1px solid var(--border);
			}

			.section-header h2 {
				margin: 0 0 0.85rem;
				font-size: clamp(1.45rem, 4vw, 2.4rem);
				letter-spacing: -0.05em;
			}

			.section-header a {
				font-family: var(--font-sans);
				font-size: 0.72rem;
				letter-spacing: 0.16em;
				text-decoration: none;
				text-transform: uppercase;
			}

			.post-list {
				display: grid;
				gap: 0.4rem;
			}

			.post-card {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 1rem;
				align-items: start;
				padding: 0.55rem 0;
				color: var(--text);
				text-decoration: none;
			}

			.post-card:hover {
				color: var(--accent);
			}

			.post-card p {
				color: var(--text-soft);
			}

			.featured-post {
				display: grid;
				grid-template-columns: minmax(10rem, 0.42fr) minmax(0, 1fr);
				gap: 1rem;
				align-items: stretch;
				margin-bottom: 1rem;
				padding: 0.8rem;
				border: 1px solid var(--border);
				border-radius: 1rem;
				background: rgba(255, 255, 255, 0.03);
			}

			.featured-post:hover {
				border-color: var(--border-strong);
				background: rgba(255, 255, 255, 0.05);
			}

			.featured-art {
				position: relative;
				min-height: 11rem;
				border: 1px solid var(--border);
				border-radius: 0.8rem;
				background-position: center;
				background-size: cover;
				overflow: hidden;
			}

			.featured-art::after {
				content: "";
				position: absolute;
				inset: 0;
				background: radial-gradient(circle at 30% 15%, rgba(255, 255, 255, 0.18), transparent 10rem);
			}

			.post-body {
				min-width: 0;
			}

			.post-card h3 {
				margin: 0;
				font-family: var(--font-sans);
				font-size: clamp(1.2rem, 2.4vw, 1.45rem);
				font-weight: 700;
				letter-spacing: -0.03em;
			}

			.post-card .summary {
				max-width: 42rem;
				margin: 0.25rem 0 0;
				font-size: 0.95rem;
				line-height: 1.45;
			}

			.post-meta {
				display: flex;
				justify-content: flex-end;
				min-width: max-content;
				padding-top: 0.2rem;
				text-align: right;
			}

			.featured-post .post-meta {
				justify-content: flex-start;
				text-align: left;
			}

			.featured-content {
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.side-stack {
				display: grid;
				gap: 1rem;
				margin-top: 2.8rem;
			}

			.panel {
				padding: 1rem;
				border: 1px solid var(--border);
				border-radius: 1rem;
				background: rgba(255, 255, 255, 0.03);
				font-family: var(--font-sans);
			}

			.panel h2 {
				margin-bottom: 0.85rem;
				font-family: var(--font-serif);
				font-size: 1.65rem;
				letter-spacing: -0.045em;
			}

			.panel p,
			.panel li {
				color: var(--muted);
				font-size: 0.9rem;
				line-height: 1.5;
			}

			.til-list,
			.project-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.til-list li,
			.project-list li {
				padding: 0.8rem 0;
				border-top: 1px solid var(--border);
			}

			.til-list a,
			.project-list a {
				display: block;
				color: var(--text-soft);
				text-decoration: none;
			}

			.til-list a:hover,
			.project-list a:hover {
				color: var(--text);
			}

			.til-list span,
			.project-list span {
				display: block;
				margin-top: 0.25rem;
				color: var(--muted);
				font-size: 0.78rem;
			}

			.work-card {
				margin-top: 0.8rem;
				padding-top: 0.8rem;
				border-top: 1px solid var(--border);
			}

			.work-card strong {
				display: block;
				color: var(--text);
			}

			.work-card a {
				display: inline-block;
				margin-top: 0.6rem;
				color: var(--accent);
				font-size: 0.78rem;
				text-decoration: none;
				text-transform: uppercase;
			}

			@media (max-width: 980px) {
				.content-grid {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 640px) {
				.featured-post,
				.post-card {
					grid-template-columns: 1fr;
				}

				.post-meta {
					justify-content: flex-start;
					text-align: left;
				}
			}

		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="home-hero" aria-labelledby="intro-title">
				<h1 id="intro-title">Kanish Sharma</h1>
				<p class="hero-copy">
					{SITE_DESCRIPTION}. I write about software, strange systems, internet culture, and whatever
					else gets stuck in the gears.
				</p>
			</section>

			<div class="content-grid">
				<section aria-labelledby="recent-title">
					<div class="section-header">
						<h2 id="recent-title">Latest Writing</h2>
						<a href="/blog">All writing</a>
					</div>
					<div class="post-list">
						{
							latestPost && (
								<a class="post-card featured-post" href={`/blog/${latestPost.id}/`}>
									<div
										class="featured-art"
										style={`background-image: linear-gradient(135deg, rgba(var(--bg-rgb), 18%), rgba(127, 179, 156, 20%)), url("${latestPost.data.heroImage ?? ''}");`}
									></div>
									<div class="featured-content">
										<div class="post-meta">
											<p class="date">
												<FormattedDate date={latestPost.data.pubDate} />
											</p>
										</div>
										<h3>{latestPost.data.title}</h3>
										<p class="summary">{latestPost.data.dek ?? latestPost.data.description}</p>
									</div>
								</a>
							)
						}
						{
							otherRecentPosts.map((post) => (
								<a class="post-card" href={`/blog/${post.id}/`}>
									<div class="post-body">
										<h3>{post.data.title}</h3>
										<p class="summary">{post.data.dek ?? post.data.description}</p>
									</div>
									<div class="post-meta">
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</a>
							))
						}
					</div>
				</section>

				<aside class="side-stack" aria-label="More from the site">
					<section class="panel" aria-labelledby="til-title">
						<h2 id="til-title">TIL</h2>
						<ul class="til-list">
							{
								recentTils.map((entry) => (
									<li>
										<a href={`/til/${entry.id}/`}>
											{entry.data.title}
											<span>
												<FormattedDate date={entry.data.pubDate} />
											</span>
										</a>
									</li>
								))
							}
						</ul>
						<a class="text-link" href="/til">More TILs</a>
					</section>

					<section class="panel" aria-labelledby="work-title">
						<h2 id="work-title">Work</h2>
						<p>Professional work and projects without making the homepage feel like a resume.</p>
						{
							currentWork && (
								<div class="work-card">
									<strong>{currentWork.data.company}</strong>
									<p>{currentWork.data.summary}</p>
									<a href="/work">View work</a>
								</div>
							)
						}
					</section>

					<section class="panel" aria-labelledby="projects-title">
						<h2 id="projects-title">Projects</h2>
						<ul class="project-list">
							{
								projects.map((project) => (
									<li>
										<a href={`/projects/${project.id}/`}>
											{project.data.title}
											<span>{project.data.description}</span>
										</a>
									</li>
								))
							}
						</ul>
					</section>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>
