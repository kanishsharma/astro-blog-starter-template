---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const workEntries = (await getCollection('work')).sort((a, b) => {
	const orderDiff = (a.data.order ?? 999) - (b.data.order ?? 999);
	return orderDiff || b.data.startDate.valueOf() - a.data.startDate.valueOf();
});

const projects = (await getCollection('projects')).sort((a, b) => {
	const orderDiff = (a.data.order ?? 999) - (b.data.order ?? 999);
	return orderDiff || a.data.title.localeCompare(b.data.title);
});

const projectsByWork = new Map<string, typeof projects>();

for (const project of projects) {
	if (!project.data.relatedWork) continue;
	const relatedProjects = projectsByWork.get(project.data.relatedWork) ?? [];
	relatedProjects.push(project);
	projectsByWork.set(project.data.relatedWork, relatedProjects);
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Work | ${SITE_TITLE}`} description="Professional work and personal projects." />
		<style>
			main {
				width: min(58rem, calc(100% - 2rem));
				margin: 0 auto;
			}

			.work-page {
				padding-bottom: 5rem;
				font-family: var(--font-sans);
			}

			.work-hero {
				margin-bottom: 3rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--border);
			}

			.eyebrow,
			.section-title {
				color: var(--muted);
				font-size: 0.9rem;
			}

			.work-hero h1 {
				max-width: 10ch;
				margin: 0.8rem 0 1rem;
				font-family: var(--font-serif);
				font-size: clamp(3.4rem, 8vw, 6.4rem);
				letter-spacing: -0.08em;
			}

			.work-hero p {
				max-width: 40rem;
				color: var(--text-soft);
				font-size: 1.08rem;
				line-height: 1.6;
			}

			.section-title {
				margin: 0 0 1.5rem;
				padding-bottom: 1.1rem;
				border-bottom: 1px solid var(--border);
			}

			.experience-list {
				display: grid;
				gap: 2.4rem;
				margin-bottom: 4.5rem;
			}

			.work-item {
				display: grid;
				grid-template-columns: 3.2rem minmax(0, 1fr);
				gap: 1.4rem;
			}

			.logo-box {
				display: grid;
				width: 3.2rem;
				height: 3.2rem;
				place-items: center;
				border: 1px solid var(--border);
				border-radius: 0.75rem;
				background: rgba(255, 255, 255, 0.03);
				color: var(--text);
				font-weight: 700;
			}

			.item-heading {
				display: flex;
				gap: 1rem;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 0.25rem;
			}

			.item-heading h2 {
				margin: 0;
				font-family: var(--font-sans);
				font-size: 1.05rem;
				font-weight: 700;
				letter-spacing: -0.02em;
			}

			.item-heading a {
				color: var(--text);
				text-decoration: none;
			}

			.item-heading a:hover {
				color: var(--accent);
			}

			.date-range,
			.role,
			.related-title {
				color: var(--muted);
			}

			.date-range {
				flex: 0 0 auto;
				font-size: 0.9rem;
			}

			.role {
				margin-bottom: 0.85rem;
			}

			.summary {
				max-width: 42rem;
				color: var(--text-soft);
				line-height: 1.6;
			}

			.related-projects {
				display: flex;
				flex-wrap: wrap;
				gap: 0.55rem;
				margin-top: 0.9rem;
			}

			.related-projects a,
			.status {
				padding: 0.25rem 0.55rem;
				border: 1px solid var(--border);
				border-radius: 999px;
				color: var(--text-soft);
				font-size: 0.76rem;
				text-decoration: none;
			}

			.projects-list {
				display: grid;
				gap: 0.65rem;
			}

			.project-row {
				display: grid;
				grid-template-columns: minmax(10rem, 0.28fr) minmax(0, 1fr) auto;
				gap: 0.8rem;
				align-items: baseline;
				padding: 0.2rem 0;
				color: var(--text-soft);
				text-decoration: none;
			}

			.project-row strong {
				color: var(--text);
			}

			.project-row span {
				color: var(--muted);
				font-size: 0.9rem;
			}

			@media (max-width: 720px) {
				.work-item {
					grid-template-columns: 1fr;
					gap: 0.8rem;
				}

				.item-heading,
				.project-row {
					display: block;
				}

				.date-range,
				.project-row span {
					display: block;
					margin-top: 0.2rem;
				}

				.status {
					display: inline-block;
					margin-top: 0.45rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="work-page">
			<section class="work-hero" aria-labelledby="work-title">
				<div class="eyebrow">Work</div>
				<h1 id="work-title">Things I have helped build.</h1>
				<p>
					A compact index of professional experience and selected projects, with deeper notes
					available on each entry.
				</p>
			</section>

			<section id="experience" aria-labelledby="experience-title">
				<h2 class="section-title" id="experience-title">Experience</h2>
				<div class="experience-list">
					{
						workEntries.map((entry) => {
							const relatedProjects = projectsByWork.get(entry.id) ?? [];

							return (
								<article class="work-item">
									<div class="logo-box" aria-hidden="true">
										{entry.data.logoText ?? entry.data.company.slice(0, 1)}
									</div>
									<div>
										<div class="item-heading">
											<h2>
												<a href={`/work/${entry.id}/`}>{entry.data.company}</a>
											</h2>
											<div class="date-range">{entry.data.displayDate}</div>
										</div>
										<div class="role">{entry.data.role}</div>
										<p class="summary">{entry.data.summary}</p>
										{
											relatedProjects.length > 0 && (
												<div class="related-projects" aria-label={`Projects related to ${entry.data.company}`}>
													{relatedProjects.map((project) => (
														<a href={`/projects/${project.id}/`}>{project.data.title}</a>
													))}
												</div>
											)
										}
									</div>
								</article>
							);
						})
					}
				</div>
			</section>

			<section id="projects" aria-labelledby="projects-title">
				<h2 class="section-title" id="projects-title">Projects</h2>
				<div class="projects-list">
					{
						projects.map((project) => (
							<a class="project-row" href={`/projects/${project.id}/`}>
								<strong>{project.data.title}</strong>
								<span>{project.data.description}</span>
								{project.data.status && <span class="status">{project.data.status}</span>}
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
