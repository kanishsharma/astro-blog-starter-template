---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} image="/blog-placeholder-about.jpg" />
		<style>
			.about-hero {
				display: grid;
				grid-template-columns: minmax(0, 0.85fr) minmax(18rem, 0.55fr);
				gap: clamp(2rem, 5vw, 5rem);
				align-items: end;
				padding-bottom: 3rem;
				border-bottom: 1px solid var(--border);
			}

			.eyebrow,
			.meta-label {
				color: var(--accent);
				font-family: var(--font-sans);
				font-size: 0.72rem;
				letter-spacing: 0.18em;
				text-transform: uppercase;
			}

			h1 {
				max-width: 10ch;
				margin: 1rem 0;
				font-size: clamp(4rem, 12vw, 9rem);
				letter-spacing: -0.085em;
			}

			.lede {
				max-width: 42rem;
				color: var(--text-soft);
				font-size: clamp(1.2rem, 2vw, 1.55rem);
				line-height: 1.4;
			}

			.portrait-card {
				min-height: 24rem;
				padding: 1.25rem;
				border: 1px solid var(--border);
				border-radius: 1.5rem;
				background:
					linear-gradient(135deg, rgba(var(--bg-rgb), 0.18), rgba(214, 179, 109, 0.18)),
					url("/blog-placeholder-about.jpg") center / cover;
				box-shadow: var(--shadow);
			}

			.content-grid {
				display: grid;
				grid-template-columns: minmax(14rem, 0.32fr) minmax(0, 1fr);
				gap: clamp(2rem, 6vw, 6rem);
				margin-top: 3rem;
			}

			.meta-card {
				position: sticky;
				top: 1rem;
				height: fit-content;
				padding: 1rem;
				border: 1px solid var(--border);
				border-radius: 1rem;
				background: var(--surface);
			}

			.meta-card ul {
				list-style: none;
				margin: 1rem 0 0;
				padding: 0;
			}

			.meta-card li {
				padding: 0.7rem 0;
				border-top: 1px solid var(--border);
				color: var(--muted);
				font-family: var(--font-sans);
				font-size: 0.82rem;
			}

			.about-copy {
				color: var(--text-soft);
				font-size: 1.08rem;
			}

			.about-copy h2 {
				margin-top: 2.5rem;
				font-size: clamp(2rem, 4vw, 3.2rem);
				letter-spacing: -0.055em;
			}

			.about-copy p {
				max-width: 44rem;
			}

			.link-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin-top: 1.5rem;
			}

			.link-row a {
				padding: 0.55rem 0.8rem;
				border: 1px solid var(--border);
				border-radius: 999px;
				font-family: var(--font-sans);
				font-size: 0.74rem;
				letter-spacing: 0.14em;
				text-decoration: none;
				text-transform: uppercase;
			}

			@media (max-width: 860px) {
				.about-hero,
				.content-grid {
					grid-template-columns: 1fr;
				}

				.meta-card {
					position: static;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero" aria-labelledby="about-title">
				<div>
					<div class="eyebrow">About</div>
					<h1 id="about-title">A place to think out loud.</h1>
					<p class="lede">
						{SITE_TITLE} is a personal writing site for essays, guides, travel notes, letters,
						and the kind of observations that need a little more room than a feed can give them.
					</p>
				</div>
				<div class="portrait-card" aria-hidden="true"></div>
			</section>

			<section class="content-grid">
				<aside class="meta-card">
					<div class="meta-label">Elsewhere</div>
					<ul>
						<li>Email: PLACEHOLDER_EMAIL_ADDRESS</li>
						<li>Writing: essays and notes</li>
						<li>Built with Astro and MDX</li>
					</ul>
				</aside>
				<div class="about-copy">
					<h2>What lives here</h2>
					<p>
						This site is designed as a quieter archive: a place for personal essays, practical
						notes, self-care references, travel fragments, and letters that can keep their shape
						over time.
					</p>
					<p>
						The design is intentionally dark, typographic, and restrained. It borrows the spirit
						of a handcrafted personal site without requiring a large JavaScript app or a heavy
						frontend dependency stack.
					</p>

					<h2>How it is built</h2>
					<p>
						The site uses Astro content collections and MDX so writing can stay close to plain
						text while still allowing richer components when they are actually needed.
					</p>
					<p>
						For now, everything is static and dark by default. There is no theme toggle, no client
						side filtering, and no React layer in the base experience.
					</p>

					<div class="link-row">
						<a href="/blog">Read writing</a>
						<a href="/rss.xml">RSS feed</a>
						<a href="mailto:PLACEHOLDER_EMAIL_ADDRESS">Contact</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
