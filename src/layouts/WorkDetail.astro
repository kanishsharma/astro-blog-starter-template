---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	kicker: string;
	meta?: string;
	links?: { label: string; url: string }[];
}

const { title, description, kicker, meta, links = [] } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(54rem, calc(100% - 2rem));
				margin: 0 auto;
			}

			.detail {
				padding-bottom: 5rem;
				font-family: var(--font-sans);
			}

			.kicker,
			.meta {
				color: var(--muted);
				font-size: 0.86rem;
			}

			.kicker {
				margin-bottom: 1rem;
			}

			h1 {
				max-width: 12ch;
				margin-bottom: 1rem;
				font-family: var(--font-serif);
				font-size: clamp(3rem, 8vw, 5rem);
				letter-spacing: -0.07em;
			}

			.description {
				max-width: 42rem;
				color: var(--text-soft);
				font-size: clamp(1.15rem, 2.3vw, 1.45rem);
				line-height: 1.5;
			}

			.link-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin: 2rem 0 2.5rem;
			}

			.link-row a {
				padding: 0.45rem 0.75rem;
				border: 1px solid var(--border);
				border-radius: 999px;
				color: var(--text-soft);
				font-size: 0.78rem;
				text-decoration: none;
			}

			.prose {
				max-width: 42rem;
				padding-top: 2rem;
				border-top: 1px solid var(--border);
				color: var(--text-soft);
				font-family: var(--font-serif);
				font-size: 1.08rem;
			}

			.prose :global(a) {
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article class="detail">
				<div class="kicker">{kicker}</div>
				<h1>{title}</h1>
				{meta && <div class="meta">{meta}</div>}
				<p class="description">{description}</p>
				{
					links.length > 0 && (
						<div class="link-row">
							{links.map((link) => (
								<a href={link.url}>{link.label}</a>
							))}
						</div>
					)
				}
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
