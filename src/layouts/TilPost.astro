---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'til'>['data'];

const { title, description, pubDate, updatedDate, likes, sourceUrl } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | TIL`} description={description} />
		<style>
			main {
				width: min(56rem, calc(100% - 2rem));
				margin: 0 auto;
			}

			.til-entry {
				padding: clamp(1rem, 3vw, 2.5rem) 0 5rem;
			}

			.entry-meta {
				margin-bottom: 1rem;
				color: var(--muted);
				font-family: var(--font-sans);
				font-size: 0.9rem;
				letter-spacing: 0.02em;
			}

			.entry-meta strong {
				color: var(--text-soft);
				font-weight: 600;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			h1 {
				max-width: 14ch;
				margin-bottom: 1.4rem;
				font-size: clamp(3rem, 8vw, 5rem);
				font-weight: 700;
				letter-spacing: -0.07em;
				text-transform: uppercase;
			}

			.description {
				max-width: 42rem;
				margin-bottom: 2.5rem;
				color: var(--text-soft);
				font-size: clamp(1.25rem, 2.6vw, 1.7rem);
				line-height: 1.45;
			}

			.entry-footer {
				display: flex;
				flex-wrap: wrap;
				gap: 0.85rem;
				align-items: center;
				margin: 2.2rem 0 3rem;
			}

			.likes {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.35rem 0.75rem;
				border-radius: 999px;
				background: var(--surface);
				color: var(--muted);
				font-family: var(--font-sans);
				font-size: 0.88rem;
			}

			.likes svg {
				width: 0.95rem;
				height: 0.95rem;
				fill: currentColor;
			}

			.source-link {
				color: var(--text-soft);
				font-family: var(--font-sans);
				font-size: 0.88rem;
			}

			.prose {
				max-width: 42rem;
				color: var(--text-soft);
				font-size: 1.08rem;
			}

			.prose :global(a) {
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article class="til-entry">
				<div class="entry-meta">
					<strong>TIL</strong> on <FormattedDate date={pubDate} />
					{
						updatedDate && (
							<span>
								{' '}
								/ updated <FormattedDate date={updatedDate} />
							</span>
						)
					}
				</div>
				<h1>{title}</h1>
				<p class="description">{description}</p>
				<div class="entry-footer">
					{
						likes !== undefined && (
							<span class="likes" aria-label={`${likes} likes`}>
								<svg viewBox="0 0 24 24" aria-hidden="true">
									<path d="M12 21s-7.2-4.4-9.6-8.8C.3 8.3 2.7 4 6.9 4c2 0 3.7 1 5.1 2.8C13.4 5 15.1 4 17.1 4c4.2 0 6.6 4.3 4.5 8.2C19.2 16.6 12 21 12 21z" />
								</svg>
								{likes}
							</span>
						)
					}
					{sourceUrl && <a class="source-link" href={sourceUrl}>Learn more</a>}
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
