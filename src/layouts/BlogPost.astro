---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
	title,
	description,
	heroImage,
	category,
	accentColor,
	theme,
} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: min(72rem, calc(100% - 2rem));
				margin: 0 auto;
			}

			article {
				--post-accent: var(--accent);
			}

			article[data-theme="moss"] {
				--post-accent: var(--accent-2);
			}

			article[data-theme="violet"] {
				--post-accent: #b7a6ff;
			}

			article[data-theme="blue"] {
				--post-accent: #9fc6ff;
			}

			article[data-theme="ember"] {
				--post-accent: #e39b77;
			}

			.prose {
				width: min(44rem, 100%);
				margin: 0 auto;
				color: var(--text-soft);
				font-size: 1.08rem;
			}

			.title {
				width: min(44rem, 100%);
				margin: 0 auto 2.5rem;
				padding: clamp(3rem, 8vw, 6rem) 0 1.8rem;
				border-bottom: 1px solid var(--border);
			}

			.title h1 {
				margin: 0 0 1rem;
				font-size: clamp(2.8rem, 7vw, 5.8rem);
				letter-spacing: -0.075em;
			}

			.category {
				margin-bottom: 0.8rem;
				color: var(--post-accent);
				font-family: var(--font-sans);
				font-size: 0.76rem;
				letter-spacing: 0.2em;
				text-transform: uppercase;
			}

			.prose :global(h2),
			.prose :global(h3) {
				color: var(--text);
				letter-spacing: -0.04em;
			}

			.prose :global(a) {
				color: var(--post-accent);
			}

			.prose :global(img) {
				margin: 1rem 0 2rem;
				border: 1px solid var(--border);
				border-radius: 1rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article data-theme={theme} style={accentColor ? `--post-accent: ${accentColor};` : undefined}>
				<div class="title">
					{category && <div class="category">{category}</div>}
					<h1>{title}</h1>
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
