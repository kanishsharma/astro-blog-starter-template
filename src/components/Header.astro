---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const isActive = (href: string) => href === pathname || href === '/' + (subpath?.[0] || '');
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About' },
	{ href: '/blog', label: 'Writing' },
	{ href: '/til', label: 'TIL' },
	{ href: '/work', label: 'Work' },
];
---

<header class="site-header">
	<div class="utility-nav">
		<button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu">
			<span class="menu-icon" aria-hidden="true"></span>
			<span>Menu</span>
		</button>
		<div class="social-links">
			<a href="mailto:PLACEHOLDER_EMAIL_ADDRESS" aria-label="Email">
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M4.5 6.75h15v10.5h-15z"></path>
					<path d="m4.5 7 7.5 6 7.5-6"></path>
				</svg>
			</a>
			<a href="https://www.linkedin.com/in/PLACEHOLDER_LINKEDIN_SLUG" target="_blank" aria-label="LinkedIn">
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M7.25 9.75v7.5"></path>
					<path d="M7.25 6.75v.01"></path>
					<path d="M11.25 17.25v-7.5"></path>
					<path d="M11.25 13.25c0-2.1 1.1-3.5 3-3.5 1.65 0 2.5 1.1 2.5 3.1v4.4"></path>
				</svg>
			</a>
		</div>
	</div>
</header>

<div class="menu-backdrop" data-menu-backdrop hidden></div>
<aside id="site-menu" class="site-menu" aria-label="Site menu" hidden>
	<div class="menu-panel">
		<div class="menu-topline">
			<div class="menu-breadcrumb">
				<a href="/">{SITE_TITLE}</a>
				<span>/</span>
				<span>Menu</span>
			</div>
			<button class="menu-close" type="button" aria-label="Close menu">&times;</button>
		</div>
		<nav class="drawer-nav" aria-label="Primary">
			{
				navItems.map((item) => (
					<a href={item.href} class:list={{ active: isActive(item.href) }}>
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="menu-group">
			<div class="menu-label">Projects</div>
			<a href="/work#projects">Personal Projects</a>
			<a href="/work#experience">Professional Work</a>
		</div>
		<div class="menu-socials" aria-label="Social links">
			<a href="mailto:PLACEHOLDER_EMAIL_ADDRESS">Email</a>
			<a href="https://www.linkedin.com/in/PLACEHOLDER_LINKEDIN_SLUG" target="_blank">LinkedIn</a>
			<a href="/rss.xml">RSS</a>
		</div>
	</div>
</aside>

<script is:inline>
	const menu = document.getElementById('site-menu');
	const backdrop = document.querySelector('[data-menu-backdrop]');
	const openButton = document.querySelector('.menu-toggle');
	const closeButton = document.querySelector('.menu-close');
	const focusableSelector = 'a[href], button:not([disabled])';

	function setMenuOpen(isOpen) {
		if (!menu || !backdrop || !openButton) return;

		menu.hidden = !isOpen;
		backdrop.hidden = !isOpen;
		openButton.setAttribute('aria-expanded', String(isOpen));
		document.body.classList.toggle('menu-open', isOpen);

		if (isOpen) {
			const firstFocusable = menu.querySelector(focusableSelector);
			firstFocusable?.focus();
		} else {
			openButton.focus();
		}
	}

	openButton?.addEventListener('click', () => setMenuOpen(true));
	closeButton?.addEventListener('click', () => setMenuOpen(false));
	backdrop?.addEventListener('click', () => setMenuOpen(false));

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape' && menu && !menu.hidden) {
			setMenuOpen(false);
		}
	});
</script>
<style>
	.site-header {
		position: relative;
		width: min(58rem, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1rem 0 0;
	}

	.utility-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		color: var(--muted);
		font-family: var(--font-sans);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.menu-toggle,
	.menu-close {
		border: 0;
		background: transparent;
		color: inherit;
		font: inherit;
		cursor: pointer;
	}

	.menu-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0;
		letter-spacing: inherit;
		text-transform: inherit;
	}

	.menu-toggle:hover {
		color: var(--text);
	}

	.menu-icon,
	.menu-icon::before,
	.menu-icon::after {
		display: block;
		width: 1.15rem;
		height: 1px;
		background: currentColor;
	}

	.menu-icon {
		position: relative;
	}

	.menu-icon::before,
	.menu-icon::after {
		content: "";
		position: absolute;
		left: 0;
	}

	.menu-icon::before {
		top: -0.35rem;
	}

	.menu-icon::after {
		top: 0.35rem;
	}

	.utility-nav a,
	.menu-panel a {
		color: inherit;
		text-decoration: none;
	}

	.utility-nav a:hover,
	.menu-panel a:hover {
		color: var(--text);
	}

	.social-links a {
		display: inline-flex;
		width: 2rem;
		height: 2rem;
		align-items: center;
		justify-content: center;
		padding: 0.4rem 0.7rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		line-height: 1;
	}

	.social-links svg {
		width: 1rem;
		height: 1rem;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.6;
	}

	.menu-backdrop {
		position: fixed;
		inset: 0;
		z-index: 40;
		background: rgba(0, 0, 0, 0.58);
		backdrop-filter: blur(8px);
	}

	.site-menu {
		position: fixed;
		inset: 0 auto 0 0;
		z-index: 50;
		width: min(28rem, 100%);
		color: var(--text);
		font-family: var(--font-sans);
	}

	.menu-panel {
		display: flex;
		min-height: 100%;
		flex-direction: column;
		padding: clamp(1.3rem, 4vw, 2rem);
		border-right: 1px solid var(--border);
		background: rgba(9, 11, 10, 0.98);
		box-shadow: var(--shadow);
	}

	.menu-topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2.6rem;
	}

	.menu-breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-soft);
		font-size: 1rem;
		font-weight: 700;
	}

	.menu-breadcrumb span {
		color: var(--muted);
	}

	.menu-close {
		color: var(--text);
		font-size: 2.1rem;
		line-height: 1;
	}

	.drawer-nav,
	.menu-group {
		display: grid;
		gap: 1.05rem;
	}

	.drawer-nav {
		margin-bottom: 2.2rem;
		font-size: clamp(1.6rem, 7vw, 2.1rem);
		font-weight: 700;
		line-height: 1.15;
	}

	.drawer-nav a {
		color: var(--muted);
	}

	.drawer-nav a.active,
	.drawer-nav a:hover {
		color: var(--text);
		font-style: normal;
	}

	.menu-group {
		margin-top: 0.6rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
		color: var(--muted);
		font-size: 1.2rem;
		font-weight: 700;
	}

	.menu-label {
		margin-bottom: 0.25rem;
		color: var(--muted);
		font-size: 0.82rem;
		font-weight: 400;
	}

	.menu-socials {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: auto;
		padding-top: 2.5rem;
		color: var(--muted);
		font-size: 0.88rem;
	}

	:global(body.menu-open) {
		overflow: hidden;
	}

	@media (max-width: 760px) {
		.social-links {
			display: none;
		}

		.utility-nav {
			justify-content: flex-start;
		}
	}

	@media (max-width: 520px) {
		.site-header {
			padding-top: 1rem;
		}

		.menu-toggle span:last-child {
			display: none;
		}
	}
</style>
