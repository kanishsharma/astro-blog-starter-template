---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<p>Handcrafted by Kanish Sharma · {today.getFullYear()}</p>
	<p class="footer-note">Writing, notes, and a softer archive of a life in motion.</p>
</footer>
<style>
	footer {
		width: min(82rem, calc(100% - 2rem));
		margin: 5rem auto 0;
		padding: 2rem 0 3.5rem;
		border-top: 1px solid var(--border);
		color: var(--muted);
		text-align: center;
		font-family: var(--font-sans);
		font-size: 0.76rem;
		letter-spacing: 0.03em;
	}
	footer p {
		margin: 0;
	}
	.footer-note {
		margin-top: 0.35rem;
		font-style: italic;
	}
</style>
